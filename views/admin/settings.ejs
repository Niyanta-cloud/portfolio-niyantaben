<%- include('../partials/admin-header') %>
<div class="admin-main">
  <h2>Settings</h2>
  <div class="card">
    <form action="/admin/settings" method="POST" enctype="multipart/form-data">
      <h3>Contact Info</h3>
      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" value="<%= settings.email || '' %>">
      </div>
      <div class="form-group">
        <label>Phone</label>
        <input type="text" name="phone" value="<%= settings.phone || '' %>">
      </div>
      <div class="form-group">
        <label>Location</label>
        <input type="text" name="location" value="<%= settings.location || '' %>">
      </div>
      <h3 style="margin-top:20px">Social Links</h3>
      <div class="form-group">
        <label>GitHub URL</label>
        <input type="url" name="github" value="<%= (settings.social && settings.social.github) || '' %>">
      </div>
      <div class="form-group">
        <label>LinkedIn URL</label>
        <input type="url" name="linkedin" value="<%= (settings.social && settings.social.linkedin) || '' %>">
      </div>
      <div class="form-group">
        <label>Twitter URL</label>
        <input type="url" name="twitter" value="<%= (settings.social && settings.social.twitter) || '' %>">
      </div>
      <h3 style="margin-top:20px">Email Notifications (SMTP)</h3>
      <p style="font-size:0.85rem;color:var(--medium-gray);margin-bottom:12px">Configure SMTP to receive email notifications when someone sends you a message.</p>
      <div class="form-row">
        <div class="form-group">
          <label>SMTP Host</label>
          <input type="text" name="smtpHost" value="<%= settings.smtpHost || '' %>" placeholder="smtp.gmail.com">
        </div>
        <div class="form-group">
          <label>SMTP Port</label>
          <input type="number" name="smtpPort" value="<%= settings.smtpPort || 587 %>">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>SMTP Username</label>
          <input type="text" name="smtpUser" value="<%= settings.smtpUser || '' %>">
        </div>
        <div class="form-group">
          <label>SMTP Password</label>
          <input type="password" name="smtpPass" value="<%= settings.smtpPass || '' %>">
        </div>
      </div>
      <h3 style="margin-top:20px">Resume / CV</h3>
      <div class="form-row">
        <div class="form-group">
          <label><i class="fas fa-flag"></i> 🇬🇧 English CV (PDF)</label>
          <input type="file" name="resumeEn" accept=".pdf">
          <% if (settings.resumeEn) { %><p style="font-size:0.85rem;margin-top:4px">Current: <a href="<%= settings.resumeEn %>" target="_blank">View</a></p><% } %>
        </div>
        <div class="form-group">
          <label><i class="fas fa-flag"></i> 🇩🇪 German CV (PDF)</label>
          <input type="file" name="resumeDe" accept=".pdf">
          <% if (settings.resumeDe) { %><p style="font-size:0.85rem;margin-top:4px">Current: <a href="<%= settings.resumeDe %>" target="_blank">View</a></p><% } %>
        </div>
      </div>
      <h3 style="margin-top:20px">Change Password</h3>
      <div class="form-group">
        <label>New Password (leave blank to keep current)</label>
        <input type="password" name="password">
      </div>
      <button type="submit" class="btn btn-primary">Save Settings</button>
    </form>
  </div>
</div>
</body>
</html>
