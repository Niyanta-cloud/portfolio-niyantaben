<%- include('../partials/admin-header') %>
<div class="admin-main">
  <h2><%= isEdit ? 'Edit' : 'Add' %> Project</h2>
  <div class="card">
    <form action="/admin/projects/<%= isEdit ? 'edit/' + item.id : 'add' %>" method="POST" enctype="multipart/form-data">
      <div class="form-group">
        <label>Name</label>
        <input type="text" name="name" value="<%= item ? item.name : '' %>" required>
      </div>
      <div class="form-group">
        <label>Description</label>
        <textarea name="description" required><%= item ? item.description : '' %></textarea>
      </div>
      <div class="form-group">
        <label>Technologies (comma-separated)</label>
        <input type="text" name="technologies" value="<%= item ? (item.technologies || []).join(', ') : '' %>" placeholder="AWS, Terraform, Docker">
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>GitHub URL</label>
          <input type="url" name="github" value="<%= item ? item.github : '' %>">
        </div>
        <div class="form-group">
          <label>Live Demo URL</label>
          <input type="url" name="demo" value="<%= item ? item.demo : '' %>">
        </div>
      </div>
      <div class="form-group">
        <label>Screenshot</label>
        <input type="file" name="screenshot" accept="image/*">
        <% if (isEdit && item.screenshot) { %><p style="font-size:0.85rem;margin-top:4px">Current: <a href="<%= item.screenshot %>" target="_blank">View</a></p><% } %>
      </div>
      <button type="submit" class="btn btn-primary">Save</button>
      <a href="/admin/projects" class="btn" style="background:var(--border)">Cancel</a>
    </form>
  </div>
</div>
</body>
</html>
