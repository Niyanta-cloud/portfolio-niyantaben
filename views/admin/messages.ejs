<%- include('../partials/admin-header') %>
<div class="admin-main">
  <h2>Messages</h2>
  <div class="card">
    <% if ((items || []).length === 0) { %>
      <p>No messages yet.</p>
    <% } else { %>
      <table>
        <thead><tr><th>Date</th><th>Name</th><th>Email</th><th>Subject</th><th>Message</th><th>File</th><th>Action</th></tr></thead>
        <tbody>
          <% items.forEach(m => { %>
            <tr>
              <td style="white-space:nowrap"><%= new Date(m.date).toLocaleDateString() %></td>
              <td><%= m.name %></td>
              <td><%= m.email %></td>
              <td><%= m.subject %></td>
              <td style="max-width:200px;overflow:hidden;text-overflow:ellipsis"><%= m.message %></td>
              <td><% if (m.attachment) { %><a href="<%= m.attachment %>" target="_blank" class="btn btn-sm btn-primary" style="text-decoration:none"><i class="fas fa-download"></i> Download</a><% } %></td>
              <td>
                <form action="/admin/messages/delete/<%= m.id %>" method="POST" style="display:inline" onsubmit="return confirm('Delete?')">
                  <button class="btn btn-sm btn-danger">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } %>
  </div>
</div>
</body>
</html>
