<%- include('../partials/admin-header') %>
<div class="admin-main">
  <h2><%= isEdit ? 'Edit' : 'Add' %> Education</h2>
  <div class="card">
    <form action="/admin/education/<%= isEdit ? 'edit/' + item.id : 'add' %>" method="POST">
      <div class="form-row">
        <div class="form-group">
          <label>Degree</label>
          <input type="text" name="degree" value="<%= item ? item.degree : '' %>" required>
        </div>
        <div class="form-group">
          <label>Institution</label>
          <input type="text" name="institution" value="<%= item ? item.institution : '' %>" required>
        </div>
      </div>
      <div class="form-group">
        <label>Period</label>
        <input type="text" name="period" value="<%= item ? item.period : '' %>" required>
      </div>
      <div class="form-group">
        <label>Locale Key for Detail</label>
        <input type="text" name="detailKey" value="<%= item ? item.detailKey : '' %>" placeholder="e.g. education_bca_detail">
      </div>
      <button type="submit" class="btn btn-primary">Save</button>
      <a href="/admin/education" class="btn" style="background:var(--border)">Cancel</a>
    </form>
  </div>
</div>
</body>
</html>
