<!DOCTYPE html>
<html lang="<%= lang %>" data-theme="">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= profile.name || 'Portfolio' %> | <%= t('home_title') %></title>
  <meta name="description" content="<%= profile.tagline %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>

<div class="badge-corner">
  <div class="badge">
    <span class="dot"></span>
    <%= t('home_open_to_work') %>
  </div>
</div>

<nav class="navbar">
  <div class="container">
    <button class="mobile-toggle" id="mobileToggle" aria-label="Menu">&#9776;</button>
    <ul class="nav-links" id="navLinks">
      <li><a href="#home" class="active"><i class="fas fa-home"></i></a></li>
      <li class="nav-dropdown">
        <a href="#about"><%= t('nav_about') %> <i class="fas fa-chevron-down" style="font-size:0.6rem;margin-left:4px"></i></a>
        <ul class="dropdown-menu">
          <li><a href="#about"><%= t('nav_about') %></a></li>
          <li><a href="#experience"><%= t('nav_experience') %></a></li>
          <li><a href="#education"><%= t('nav_education') %></a></li>
          <li><a href="#skills"><%= t('nav_skills') %></a></li>
          <li><a href="#certifications"><%= t('nav_certifications') %></a></li>
        </ul>
      </li>
      <li class="nav-dropdown">
        <a href="#projects"><%= t('nav_projects') %> <i class="fas fa-chevron-down" style="font-size:0.6rem;margin-left:4px"></i></a>
        <ul class="dropdown-menu">
          <li><a href="#projects"><%= t('nav_projects') %></a></li>
          <li><a href="<%= settings.social.github %>" target="_blank">GitHub</a></li>
        </ul>
      </li>
      <li class="nav-dropdown">
        <a href="#contact"><%= t('nav_contact') %> <i class="fas fa-chevron-down" style="font-size:0.6rem;margin-left:4px"></i></a>
        <ul class="dropdown-menu">
          <li><a href="#resume"><%= t('nav_resume') %></a></li>
          <li><a href="#languages">Languages</a></li>
          <li><a href="#faq"><%= t('nav_faq') %></a></li>
          <li><a href="#contact"><%= t('nav_contact') %></a></li>
          <li><a href="/admin/login" style="border-top:1px solid rgba(255,255,255,0.1);margin-top:4px;padding-top:12px !important"><i class="fas fa-lock" style="font-size:0.7rem;margin-right:6px"></i>Admin</a></li>
        </ul>
      </li>
    </ul>
    <div class="nav-controls">
      <select class="lang-select" id="langSelect" onchange="changeLang(this.value)">
        <% ['en', 'de'].forEach(l => { %>
          <option value="<%= l %>" <%= lang === l ? 'selected' : '' %>><%= l.toUpperCase() %></option>
        <% }) %>
      </select>
      <button class="theme-btn" id="themeToggle" aria-label="<%= t('theme_toggle') %>">&#9790;</button>
    </div>
  </div>
</nav>
